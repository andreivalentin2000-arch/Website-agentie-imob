# Copy to .env.local and fill in real values.

# Calendly booking link, e.g. https://calendly.com/romanian-heritage-estates/private-consultation
NEXT_PUBLIC_CALENDLY_URL=

# CRM inbound webhook URL (HubSpot, Pipedrive, custom endpoint, etc.)
CRM_WEBHOOK_URL=

# Public form endpoint used when deploying as a static site, e.g. Formspree/Getform/custom webhook.
NEXT_PUBLIC_LEAD_ENDPOINT=
